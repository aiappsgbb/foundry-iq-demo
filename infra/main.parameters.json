{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "environment": {
      "value": "${AZURE_ENVIRONMENT=dev}"
    },
    "chatModelName": {
      "value": "${AZURE_CHAT_MODEL=gpt-4o-mini}"
    },
    "embeddingModelName": {
      "value": "${AZURE_EMBEDDING_MODEL=text-embedding-3-large}"
    },
    "webImageName": {
      "value": "${SERVICE_WEB_IMAGE_NAME=}"
    },
    "existingFoundryId": {
      "value": "${AZURE_EXISTING_FOUNDRY_ID=}"
    },
    "existingChatDeploymentName": {
      "value": "${AZURE_EXISTING_CHAT_DEPLOYMENT=}"
    },
    "existingEmbeddingDeploymentName": {
      "value": "${AZURE_EXISTING_EMBEDDING_DEPLOYMENT=}"
    }
  }
}
